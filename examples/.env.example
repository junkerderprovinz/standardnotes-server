# Standard Notes – self-hosted backend example .env
# Mirrors https://github.com/standardnotes/server/blob/main/.env.sample
# with annotations specific to the Unraid community template.
#
# This file is for reference / non-Unraid use only. The Unraid template
# exposes every variable below as a UI field.

######
# DB #
######

# IP address of your MariaDB container, reachable from the
# Standard Notes server. The Unraid template asks for an IP
# (e.g. 192.168.20.71) — IPs are unambiguous across bridge / br0 /
# VLAN setups. Use a static / DHCP-reserved address.
DB_HOST=192.168.20.71
DB_PORT=3306
DB_USERNAME=std_notes_user
DB_PASSWORD=replace-with-strong-password
DB_DATABASE=standard_notes_db
# Internal driver value REQUIRED for MariaDB. Standard Notes / TypeORM
# uses the "mysql" driver string to talk to MariaDB. Do not change.
DB_TYPE=mysql

#########
# CACHE #
#########

# IP address of your Redis container, e.g. 192.168.20.72.
# This template does not expose a Redis password — the official
# standardnotes/server image does not document a Redis-auth env var.
# Keep Redis on a trusted VLAN / private bridge.
REDIS_HOST=192.168.20.72
REDIS_PORT=6379
CACHE_TYPE=redis

########
# KEYS #
########
# Generate each with: openssl rand -hex 32
# Treat as write-once: rotating AUTH_SERVER_ENCRYPTION_SERVER_KEY
# renders existing server-side data unreadable.
AUTH_JWT_SECRET=
AUTH_SERVER_ENCRYPTION_SERVER_KEY=
VALET_TOKEN_SECRET=

############
# OPTIONAL #
############
# Public HTTPS URL of the files server, if you reverse-proxy it on
# its own subdomain (recommended for full attachment support), e.g.
# https://files.standardnotes.bottich.lol. Leave empty if you do not
# need attachments — note creation, editing, and sync work without
# it. Single-domain path proxying (one host, /files/* prefix) is not
# reliably supported by the upstream image.
# PUBLIC_FILES_SERVER_URL=https://files.standardnotes.bottich.lol

# Cookie domain for the API session cookies. Behind a reverse proxy
# this MUST match the public sync host (e.g. standardnotes.bottich.lol),
# and the proxy must serve HTTPS — otherwise Secure cookies are
# dropped and the server logs:
#   "No cookies provided for cookie-based session token"
# which can trigger a /v1/items sync loop and (in turn) note
# duplication. Leave empty only for direct localhost access.
# See docs/sync-loop-troubleshooting.md.
# COOKIE_DOMAIN=standardnotes.bottich.lol

{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":semanticCommits",
    ":dependencyDashboard",
    ":enableVulnerabilityAlertsWithLabel(security)"
  ],
  "timezone": "Europe/Vienna",
  "schedule": ["before 6am on monday"],
  "labels": ["dependencies"],
  "prHourlyLimit": 4,
  "prConcurrentLimit": 6,
  "packageRules": [
    {
      "description": "Standard Notes server upstream image",
      "matchPackageNames": ["standardnotes/server"],
      "groupName": "Standard Notes server",
      "commitMessageTopic": "Standard Notes server",
      "commitMessagePrefix": "feat:",
      "labels": ["upstream-bump"]
    },
    {
      "description": "LocalStack image (used for S3 bucket initialization)",
      "matchPackageNames": ["localstack/localstack"],
      "groupName": "LocalStack",
      "commitMessageTopic": "LocalStack",
      "commitMessagePrefix": "feat:",
      "labels": ["upstream-bump"]
    },
    {
      "description": "GitHub Actions: auto-merge minor/patch/digest",
      "matchManagers": ["github-actions"],
      "matchUpdateTypes": ["minor", "patch", "digest"],
      "automerge": true,
      "automergeType": "branch",
      "commitMessagePrefix": "ci:",
      "labels": ["github-actions"]
    },
    {
      "description": "GitHub Actions major: manual PRs",
      "matchManagers": ["github-actions"],
      "matchUpdateTypes": ["major"],
      "commitMessagePrefix": "ci:",
      "labels": ["github-actions", "major-update"]
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "description": "Track standardnotes/server image tag in the Unraid template (skipped for :latest, used if we ever pin)",
      "managerFilePatterns": ["/templates/standardnotes-server\\.xml$/"],
      "matchStrings": [
        "<Repository>(?<depName>standardnotes/server):(?<currentValue>[^<]+)</Repository>"
      ],
      "datasourceTemplate": "docker"
    },
    {
      "customType": "regex",
      "description": "Track localstack/localstack image tag in the LocalStack template",
      "managerFilePatterns": ["/templates/standardnotes-localstack\\.xml$/"],
      "matchStrings": [
        "<Repository>(?<depName>localstack/localstack):(?<currentValue>[^<]+)</Repository>"
      ],
      "datasourceTemplate": "docker"
    },
    {
      "customType": "regex",
      "description": "Upstream digest watcher: notify us when standardnotes/server:latest is re-pushed",
      "managerFilePatterns": ["/^\\.renovate-watch\\.txt$/"],
      "matchStrings": [
        "(?<depName>standardnotes/server)@(?<currentDigest>sha256:[a-f0-9]{64})"
      ],
      "currentValueTemplate": "latest",
      "datasourceTemplate": "docker"
    }
  ]
}
